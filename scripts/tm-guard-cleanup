#!/usr/bin/env bash
#
# tm-guard-cleanup — Clean up session state files.
#
# Called by: SessionEnd hook
# Removes the sentinel and manifest files for this session.
# Snapshots themselves are left for macOS to prune naturally.

set -euo pipefail

readonly STATE_DIR="${TMPDIR:-/tmp}/tm-guard"

session_id="$(jq -r '.session_id // empty')" || exit 0
[ -n "$session_id" ] || exit 0

rm -f "$STATE_DIR/armed-${session_id}"
rm -f "$STATE_DIR/last-snap-${session_id}"
